rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'webdev.austrc@gmail.com'
        ];
    }

    match /{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
